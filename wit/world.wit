package privasys:test-app;

world test-app {
    // ── WASI imports ──────────────────────────────────────────────
    import wasi:io/error@0.2.0;
    import wasi:io/poll@0.2.0;
    import wasi:io/streams@0.2.0;
    import wasi:random/random@0.2.0;
    import wasi:clocks/wall-clock@0.2.0;
    import wasi:filesystem/types@0.2.0;
    import wasi:filesystem/preopens@0.2.0;

    // ── Enclave OS platform imports ──────────────────────────────
    import privasys:enclave-os/https@0.1.0;
    import privasys:enclave-os/auth@0.1.0;

    // ── Type definitions ──────────────────────────────────────────

    /// Analysis output format.
    enum output-format {
        /// Return results as plain text.
        text,
        /// Return results as a JSON string.
        json,
        /// Return results as comma-separated values.
        csv,
    }

    /// Configuration for the analyse-data function.
    record analysis-config {
        /// Whether to include summary statistics (mean, min, max).
        include-stats: bool,
        /// Optional label to prefix the output.
        label: option<string>,
        /// Desired output format.
        format: output-format,
    }

    // ── Exported test functions ───────────────────────────────────

    /// Return a greeting from inside the enclave.
    /// @auth public
    export hello: func() -> string;

    /// Generate a random number between 1 and 100 using the hardware RNG (RDRAND).
    /// @auth public
    export get-random: func() -> u32;

    /// Return the current wall-clock time as seconds.nanoseconds (UTC).
    /// @auth public
    export get-time: func() -> string;

    /// Store a value in the enclave's sealed key-value store.
    /// @auth public
    export kv-store: func(
        /// The key to store the value under.
        key: string,
        /// The value to persist (encrypted at rest).
        value: string,
    ) -> string;

    /// Read a value from the enclave's sealed key-value store.
    /// @auth public
    export kv-read: func(
        /// The key to look up.
        key: string,
    ) -> string;

    /// Fetch the latest headlines from lemonde.fr over attestable HTTPS.
    /// @auth public
    export fetch-headlines: func() -> string;

    /// Analyse a list of numeric data points inside the enclave.
    ///
    /// Computes summary statistics over the input and returns
    /// the result in the requested output format. All computation
    /// happens within the hardware trust boundary.
    /// @auth public
    export analyse-data: func(
        /// The numeric data points to analyse.
        values: list<f64>,
        /// Configuration controlling output format and options.
        config: analysis-config,
    ) -> string;

    /// Result returned by the auth-gated hello functions.
    record auth-hello-result {
        /// Caller's identity (sub) as seen by the enclave.
        caller: string,
        /// Roles the caller holds.
        roles: list<string>,
        /// Human-readable greeting from inside the enclave.
        message: string,
        /// Wall-clock seconds since the Unix epoch.
        timestamp-seconds: u64,
        /// Sub-second nanoseconds component of the timestamp.
        timestamp-nanos: u32,
        /// TEE technology this enclave runs on (e.g. "sgx", "tdx").
        enclave: string,
    }

    /// Return sensitive data that should only be accessible to
    /// authenticated users.
    ///
    /// The runtime enforces the auth policy declared below before
    /// the function is called — the app itself does not need to
    /// check credentials.
    /// @auth authenticated
    export auth-hello: func() -> auth-hello-result;

    /// Return a greeting that requires the caller to hold the
    /// "hello-role" role.
    ///
    /// The runtime verifies the caller's roles before dispatch —
    /// the function itself is role-unaware.
    /// @auth role(hello-role)
    export role-hello: func() -> auth-hello-result;

    /// A paid API demonstrating x-privasys.price end to end: each
    /// successful call charges the caller 5,000 credits (0.5p), of which
    /// the app developer earns 85%. No exemptions — every caller pays.
    ///
    /// The price is declared here in the measured WIT, enforced by the
    /// attested runtime, and charged only on success: the fee a caller
    /// pays is exactly the price this annotation advertises.
    /// @auth authenticated
    /// @price {"credits":5000,"payer":"caller"}
    export priced-hello: func() -> auth-hello-result;

    /// A paid API with a wallet exemption: each successful call charges
    /// the caller 10,000 credits (1p), except callers whose token carries
    /// the Privasys wallet class marker — they pay nothing (the developer
    /// still bears the compute, a deliberate adoption lever). Clients show
    /// wallet users a "free for you" badge instead of the charge consent.
    /// @auth authenticated
    /// @price {"credits":10000,"payer":"caller","free_for":["wallet"]}
    export priced-hello-exempt-wallet: func() -> auth-hello-result;
}
